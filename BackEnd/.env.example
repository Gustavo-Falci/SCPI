# ----------------------------------------------------------------------------
# SCPI - BackEnd: variáveis de ambiente (template).
# Copie para `.env` e preencha com valores reais. NUNCA comite o .env.
# ----------------------------------------------------------------------------

# PostgreSQL
DB_HOST=
DB_PORT=5432
DB_NAME=scpi_db
DB_USER=
DB_PASSWORD=

# JWT
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — origens separadas por vírgula (sem wildcard)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET_NAME=
COLLECTION_ID=
