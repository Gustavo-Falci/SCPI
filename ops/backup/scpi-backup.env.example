# Config do backup SCPI — copiar para /etc/scpi-backup.env
#   sudo cp scpi-backup.env.example /etc/scpi-backup.env
#   sudo chown root:root /etc/scpi-backup.env && sudo chmod 600 /etc/scpi-backup.env
# HEALTHCHECK_URL é SEGREDO: quem tem a URL consegue mascarar falha de backup.

# --- OCI (obrigatórias) ---
# Namespace do tenancy: `oci os ns get` ou console OCI
OCI_NAMESPACE=
OCI_BUCKET=scpi-backups

# --- Alerta (obrigatória) ---
# URL de ping do check "scpi-backup" no healthchecks.io
HEALTHCHECK_URL=

# --- Postgres (obrigatórias) ---
PGUSER=scpi
PGDATABASE=scpi

# --- Opcionais (defaults do script) ---
#BACKUP_DIR=/var/backups/scpi
#OCI_BIN=/opt/oci-cli/bin/oci
#PGHOST=127.0.0.1
#PGPASSFILE=/root/.pgpass
