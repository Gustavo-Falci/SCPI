# ============================================================
# SCPI — Template de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# ============================================================

# ---- Banco de Dados PostgreSQL (obrigatório) ----
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_POOL_MIN=
DB_POOL_MAX=
# Timeout (s) para abrir conexão. Banco fora → erro rápido em vez de pendurar 60s. Default 3.
DB_CONNECT_TIMEOUT=

# ---- JWT (obrigatório) ----
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=

# ---- Ambiente ----
# Defina como "production" para habilitar HSTS e demais hardenings que exigem HTTPS.
# Em dev (HTTP local), deixe vazio para não forçar HTTPS no browser via HSTS.
ENVIRONMENT=

# ---- CORS (obrigatório em produção) ----
# Lista de origens permitidas, separadas por vírgula.
# Em dev, pode deixar vazio — o backend usará localhost apenas.
ALLOWED_ORIGINS=

# ---- AWS (obrigatório) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
COLLECTION_ID=
BUCKET_NAME=

# ---- Notificações por Email (Resend) ----
# Crie em resend.com → API Keys → Create API Key
RESEND_API_KEY=
# Use "onboarding@resend.dev" para testes, ou "Nome <email@dominio.com>" em produção
RESEND_FROM_EMAIL=SCPI <noreply@seudominio.com>

# ---- Admin (credenciais do usuário administrador) ----
ADMIN_NOME=
ADMIN_EMAIL=
ADMIN_SENHA=

# ---- Admin Portal (Vite) ----
# IP da máquina que roda o backend, acessível pelo navegador do dev.
VITE_API_URL=http://localhost:8000

# ---- App Mobile (Expo) ----
# IP da máquina que roda o backend, acessível pelo celular na mesma rede.
EXPO_PUBLIC_API_URL=http://XXX:8000

# ---- Câmera local (script de reconhecimento) ----
# URL da API que o script reconhecimento_tempo_real.py vai consumir.
# Em produção use https://xxx.xxx. Em dev local, http://localhost:8000.
SCPI_API_URL=

# Token estático que autentica o script reconhecimento_tempo_real.py na API.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Não commitar o valor real. Rotacionar periodicamente.
CAMERA_SERVICE_TOKEN=

# Nome da sala onde este computador/câmera está instalado (deve bater com o campo "sala" nos horários).
CAMERA_SALA=

# ---------------------------------------------------------------------------
# Thresholds de reconhecimento facial (similaridade mínima 0-100).
# Centralizar evita divergência entre handlers e dificulta downgrade silencioso.
# Valores mais altos = menos false positives, mais false negatives.
# ---------------------------------------------------------------------------
# Selfie no app — câmera frontal próxima, ambiente controlado pelo aluno.
FACE_MATCH_THRESHOLD_SELFIE=

# Câmera fixa na sala — distância variável, iluminação irregular, múltiplos rostos.
# Valor menor reflete maior tolerância empírica, NÃO menor exigência de segurança.
# Revisar se a taxa de false positives crescer.
FACE_MATCH_THRESHOLD_SALA=

# ---- LGPD Export — Chave HMAC (obrigatório) ----
# Assina manifesto de integridade do export de dados pessoais (Art. 18 §1).
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SCPI_EXPORT_HMAC_KEY=
